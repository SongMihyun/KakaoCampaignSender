# ----------------------------
# TRACE
# ----------------------------
KAKAO_TRACE=1

# ----------------------------
# Error report on/off
# ----------------------------
KCS_ERROR_REPORT_ENABLED=1

# ----------------------------
# Mail target
# ----------------------------
KCS_ERROR_REPORT_TO=idblackcat@gmail.com
KCS_ERROR_REPORT_FROM=your_sender@gmail.com

# ----------------------------
# SMTP
# Gmail App Password 사용
# 일반 비밀번호 사용 금지
# ----------------------------
KCS_ERROR_REPORT_SMTP_HOST=smtp.gmail.com
KCS_ERROR_REPORT_SMTP_PORT=587
KCS_ERROR_REPORT_SMTP_USER=your_sender@gmail.com
KCS_ERROR_REPORT_SMTP_PASS=your_gmail_app_password

# ----------------------------
# Subject / throttling
# ----------------------------
KCS_ERROR_REPORT_SUBJECT_PREFIX=[KCS][ERROR][TEST]
KCS_ERROR_REPORT_MAX_PER_RUN=5
KCS_ERROR_REPORT_COOLDOWN_SEC=60