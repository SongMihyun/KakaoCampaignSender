#!/bin/sh
MSG_FILE="$1"
SOURCE="$2"

if [ -z "$MSG_FILE" ]; then
  exit 0
fi

if command -v py >/dev/null 2>&1; then
  py -3 scripts/commit_message_helper.py "$MSG_FILE" "$SOURCE"
  exit $?
fi

if command -v python >/dev/null 2>&1; then
  python scripts/commit_message_helper.py "$MSG_FILE" "$SOURCE"
  exit $?
fi

exit 0